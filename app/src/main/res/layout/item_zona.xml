<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"

    app:cardBackgroundColor="@color/eco_blanco"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/eco_borde"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textoNombreZona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/eco_verde_oscuro"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textoTipoZona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:textColor="@color/eco_texto_secundario"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/textoSectorZona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/eco_texto_secundario"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/textoMunicipioZona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/eco_texto_secundario"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/textoHorarioZona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:textColor="@color/eco_texto_principal"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>