<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eco_fondo"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="14dp"
    android:paddingEnd="18dp"
    android:paddingBottom="14dp">

    <!-- Encabezado -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/titulo_puntos_recoleccion"
            android:textColor="@color/eco_verde_oscuro"
            android:textSize="23sp"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/accion_volver"
            android:textAllCaps="false"
            android:textColor="@color/eco_verde_oscuro"
            android:textSize="14sp"

            app:backgroundTint="@color/eco_verde_claro"
            app:cornerRadius="14dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="@string/descripcion_puntos_recoleccion"
        android:textColor="@color/eco_texto_secundario"
        android:textSize="14sp"/>

    <!-- Estado de carga -->

    <ProgressBar
        android:id="@+id/indicadorCarga"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:indeterminateTint="@color/eco_verde_principal"/>

    <TextView
        android:id="@+id/textoEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/cargando_puntos"
        android:textColor="@color/eco_texto_secundario"
        android:textSize="14sp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReintentar"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:text="@string/accion_reintentar"
        android:textAllCaps="false"
        android:visibility="gone"

        app:backgroundTint="@color/eco_verde_principal"
        app:cornerRadius="14dp"/>

    <!-- Lista de zonas -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listaZonas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        android:visibility="gone"/>

</LinearLayout>