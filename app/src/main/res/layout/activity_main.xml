<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/eco_fondo">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- Encabezado -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_principal"
            android:textColor="@color/eco_verde_oscuro"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/frase_principal"
            android:textColor="@color/eco_verde_principal"
            android:textSize="15sp"
            android:textStyle="italic"/>

        <!-- Tarjeta principal -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"

            app:cardBackgroundColor="@color/eco_verde_principal"
            app:cardCornerRadius="22dp"
            app:cardElevation="5dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/eco_verde_claro"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="@string/etiqueta_ambiental"
                    android:textColor="@color/eco_verde_oscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/descripcion_inicio"
                    android:textColor="@color/eco_blanco"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Opciones -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="@string/titulo_servicios"
            android:textColor="@color/eco_texto_principal"
            android:textSize="21sp"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClasificar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:text="@string/boton_clasificar"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"

            app:backgroundTint="@color/eco_verde_principal"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPuntos"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/boton_puntos"
            android:textAllCaps="false"
            android:textColor="@color/eco_verde_oscuro"
            android:textSize="16sp"
            android:textStyle="bold"

            app:backgroundTint="@color/eco_verde_claro"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReportar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/boton_reportar"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"

            app:backgroundTint="@color/eco_verde_oscuro"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInformacion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/boton_informacion"
            android:textAllCaps="false"
            android:textColor="@color/eco_verde_oscuro"
            android:textSize="16sp"
            android:textStyle="bold"

            app:backgroundTint="@color/eco_blanco"
            app:cornerRadius="16dp"
            app:strokeColor="@color/eco_verde_principal"
            app:strokeWidth="1dp"/>

        <!-- Información de integración -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"

            app:cardBackgroundColor="@color/eco_blanco"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/eco_borde"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_api"
                    android:textColor="@color/eco_verde_oscuro"
                    android:textSize="17sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/descripcion_api"
                    android:textColor="@color/eco_texto_secundario"
                    android:textSize="14sp"
                    android:lineSpacingExtra="3dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>