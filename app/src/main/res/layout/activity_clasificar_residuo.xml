<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eco_fondo"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <!-- Encabezado compacto -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/titulo_clasificar"
                android:textColor="@color/eco_verde_oscuro"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVolver"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/accion_volver"
                android:textAllCaps="false"
                android:textColor="@color/eco_verde_oscuro"
                android:textSize="14sp"

                app:backgroundTint="@color/eco_verde_claro"
                app:cornerRadius="14dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/descripcion_clasificar"
            android:textColor="@color/eco_texto_secundario"
            android:textSize="15sp"/>

        <!-- Campo del residuo -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/contenedorResiduo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:hint="@string/pista_residuo"

            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxStrokeColor="@color/eco_verde_principal"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/campoResiduo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"
                android:maxLength="100"
                android:maxLines="1"
                android:textSize="16sp"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEjecutarClasificacion"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:text="@string/boton_clasificar_residuo"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"

            app:backgroundTint="@color/eco_verde_principal"
            app:cornerRadius="14dp"/>

        <!-- Resultado -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tarjetaResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"

            app:cardBackgroundColor="@color/eco_resultado_gris"
            app:cardCornerRadius="18dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/eco_borde"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="130dp"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_resultado"
                    android:textColor="@color/eco_texto_principal"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/textoCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/resultado_pendiente"
                    android:textColor="@color/eco_texto_principal"
                    android:textSize="19sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/textoOrientacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/orientacion_pendiente"
                    android:textColor="@color/eco_texto_secundario"
                    android:textSize="14sp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Ayuda -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/eco_blanco"
            android:padding="14dp"
            android:text="@string/ejemplos_residuos"
            android:textColor="@color/eco_texto_secundario"
            android:textSize="13sp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>